# RPC del nodo lnet
LNET_RPC=http://<ip-de-tu-nodo-lnet>

# Writer node de lnet que aprueba las transacciones (modelo de gas LAC-NET)
NODE_ADDRESS=0x...

# trustedForwarder del modelo de gas (BaseRelayRecipient)
#   local / open-protestnet = 0xa4B5eE2906090ce2cDbf5dfff944db26f397037D
#   mainnet                  = 0xEAA5420AF59305c5ecacCB38fcDe70198001d147
TRUSTED_FORWARDER=0xEAA5420AF59305c5ecacCB38fcDe70198001d147

# Google Cloud KMS — clave EC_SIGN_SECP256K1_SHA256
KMS_PROJECT=mi-proyecto-gcp
KMS_LOCATION=global
KMS_KEYRING=lnet-keyring
KMS_KEY=lnet-signer
KMS_KEY_VERSION=1

# Credenciales de la service account con rol roles/cloudkms.signerVerifier
# (Application Default Credentials). Apunta al JSON de la service account.
GOOGLE_APPLICATION_CREDENTIALS=/ruta/a/service-account.json

# Opcional: si se define, check-deployer valida que la address derivada de la
# clave de KMS coincida con este valor.
DEPLOYER_ADDRESS=
