# ─── Producción (mainnet LNet) ──────────────────────────────────────────────
# Copia a .env y completa los valores reales. NO lo commitees (.env está en .gitignore).

# RPC del nodo lnet de producción
LNET_RPC=https://<tu-nodo-mainnet-lnet>

# Writer node de mainnet que aprueba las transacciones (modelo de gas LAC-NET)
NODE_ADDRESS=0x...

# trustedForwarder de MAINNET (BaseRelayRecipient)
TRUSTED_FORWARDER=0xEAA5420AF59305c5ecacCB38fcDe70198001d147

# Google Cloud KMS — clave secp256k1 HSM (creada por scripts/setup-kms.sh)
# secp256k1 es HSM-only: KMS_LOCATION debe ser una región con Cloud HSM (no 'global').
KMS_PROJECT=mi-proyecto-gcp
KMS_LOCATION=us-east1
KMS_KEYRING=lnet-prod
KMS_KEY=lnet-signer
KMS_KEY_VERSION=1

# Service account con rol roles/cloudkms.signerVerifier (Application Default Credentials).
# Guarda el JSON fuera del repo, con permisos restringidos (chmod 600).
GOOGLE_APPLICATION_CREDENTIALS=/ruta/segura/sa-prod.json

# Address que imprime setup-kms.sh; check-deployer valida que coincida con la clave.
DEPLOYER_ADDRESS=0x...
